generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
}

enum Role {
  GUEST
  DONOR
  JOURNALIST
  ADMIN
}

enum ReportStatus {
  PENDING
  APPROVED
  REJECTED
}

enum ProjectCategory {
  WATER
  FOOD
  MEDICAL
  EDUCATION
  EMERGENCY
}

enum SponsorshipType {
  STUDENT
  FAMILY
  VILLAGE_PROJECT
}

enum SponsorshipStatus {
  OPEN
  FULLY_FUNDED
  COMPLETED
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  password      String?
  role          Role      @default(DONOR)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts          Account[]
  sessions          Session[]
  donations         Donation[]
  reports           Report[]
  userSponsorships  UserSponsorship[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Report {
  id          String       @id @default(cuid())
  slug        String?      @unique
  title       String
  location    String
  story       String       @db.Text
  familiesAffected Int     @default(0)
  amountNeeded Float       @default(0)
  raised      Float        @default(0)
  category    ProjectCategory
  status      ReportStatus @default(PENDING)
  images      String[]
  videoUrl    String?
  authorId    String
  author      User         @relation(fields: [authorId], references: [id])
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  sponsorships Sponsorship[]
  donations    Donation[]
}

model Sponsorship {
  id          String            @id @default(cuid())
  type        SponsorshipType
  status      SponsorshipStatus @default(OPEN)
  displayName String
  story       String            @db.Text
  goal        Float
  raised      Float             @default(0)
  images      String[]
  videoUrl    String?
  reportId    String?
  report      Report?           @relation(fields: [reportId], references: [id])
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  milestones   Milestone[]
  donations    Donation[]
  sponsors     UserSponsorship[]
}

model UserSponsorship {
  id            String      @id @default(cuid())
  userId        String
  sponsorshipId String
  user          User        @relation(fields: [userId], references: [id])
  sponsorship   Sponsorship @relation(fields: [sponsorshipId], references: [id])
  createdAt     DateTime    @default(now())

  @@unique([userId, sponsorshipId])
}

model Milestone {
  id            String      @id @default(cuid())
  sponsorshipId String
  sponsorship   Sponsorship @relation(fields: [sponsorshipId], references: [id])
  date          DateTime
  title         String
  description   String
  createdAt     DateTime    @default(now())
}

model Donation {
  id              String   @id @default(cuid())
  amount          Float
  currency        String   @default("usd")
  stripePaymentId String?  @unique
  donorEmail      String?
  donorName       String?
  userId          String?
  user            User?    @relation(fields: [userId], references: [id])
  reportId        String?
  report          Report?  @relation(fields: [reportId], references: [id])
  sponsorshipId   String?
  sponsorship     Sponsorship? @relation(fields: [sponsorshipId], references: [id])
  message         String?
  isAnonymous     Boolean  @default(false)
  createdAt       DateTime @default(now())
}

model AuditLog {
  id        String   @id @default(cuid())
  action    String
  actorId   String?
  targetId  String?
  metadata  Json?
  createdAt DateTime @default(now())
}

model EmailReceipt {
  id         String   @id @default(cuid())
  donationId String   @unique
  sentAt     DateTime @default(now())
  email      String
}

model ImpactReport {
  id          String   @id @default(cuid())
  title       String
  month       Int
  year        Int
  totalRaised Float
  trucksDelivered Int  @default(0)
  studentsSupported Int @default(0)
  familiesHelped Int   @default(0)
  summary     String   @db.Text
  isPublished Boolean  @default(false)
  publishedAt DateTime?
  createdAt   DateTime @default(now())
}
