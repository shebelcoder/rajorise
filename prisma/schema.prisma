generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ── ENUMS ─────────────────────────────────────────────

enum Role {
  DONOR
  JOURNALIST
  ADMIN
  PROCUREMENT_OFFICER
  FIELD_AGENT
}

enum ReportStatus {
  DRAFT
  PENDING
  APPROVED
  REJECTED
  FUNDING
  AWAITING_PROCUREMENT
  IN_PROCUREMENT
  COMPLETED
  ARCHIVED
}

enum PurchaseOrderStatus {
  DRAFT
  PENDING_APPROVAL
  APPROVED
  PAID
  FULFILLED
  CANCELLED
}

// ── USERS ─────────────────────────────────────────────

model User {
  id             String    @id @default(cuid())
  email          String    @unique
  name           String?
  passwordHash   String?
  role           Role      @default(DONOR)
  isActive       Boolean   @default(true)
  sessionVersion Int       @default(0)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  lastLoginAt    DateTime?
  lastLoginIp    String?

  donations      Donation[]
  purchaseOrders PurchaseOrder[]
  auditLogs      AuditLog[]
  permissions    UserPermission[]

  @@index([email])
  @@index([role])
}

model Permission {
  id          String           @id @default(cuid())
  key         String           @unique
  description String?
  users       UserPermission[]
}

model UserPermission {
  id           String     @id @default(cuid())
  userId       String
  permissionId String
  grantedBy    String
  createdAt    DateTime   @default(now())

  user       User       @relation(fields: [userId], references: [id])
  permission Permission @relation(fields: [permissionId], references: [id])

  @@unique([userId, permissionId])
}

// ── VILLAGES (dynamic, user-addable) ──────────────────

model Village {
  id        String   @id @default(cuid())
  name      String
  district  String
  region    String   @default("Gedo")
  addedById String?
  createdAt DateTime @default(now())

  @@unique([name, district, region])
  @@index([district])
  @@index([region])
}

// ── CASES / REPORTS ───────────────────────────────────

model Report {
  id               String       @id @default(cuid())
  slug             String       @unique
  title            String
  summary          String
  fullStory        String       @db.Text
  location         String?
  country          String       @default("Somalia")
  region           String       @default("Gedo")
  district         String?
  village          String?
  status           ReportStatus @default(PENDING)
  goalAmount       Decimal      @db.Decimal(12, 2)
  raisedAmount     Decimal      @default(0) @db.Decimal(12, 2)
  currency         String       @default("USD")
  journalistId     String
  approvedById     String?
  approvedAt       DateTime?
  rejectedReason   String?
  featuredImageUrl String?
  mediaUrls        String[]
  isUrgent         Boolean      @default(false)
  publishedAt      DateTime?
  completedAt      DateTime?
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  donations      Donation[]
  fundPool       FundPool?
  purchaseOrders PurchaseOrder[]
  auditLogs      AuditLog[]

  @@index([status])
  @@index([slug])
  @@index([region])
}

// ── STUDENTS ──────────────────────────────────────────

model Student {
  id           String       @id @default(cuid())
  slug         String       @unique
  name         String
  age          Int?
  grade        String?
  location     String?
  country      String       @default("Somalia")
  region       String       @default("Gedo")
  district     String?
  village      String?
  story        String       @db.Text
  imageUrl     String?
  goalAmount   Decimal      @db.Decimal(12, 2)
  raisedAmount Decimal      @default(0) @db.Decimal(12, 2)
  currency     String       @default("USD")
  status       ReportStatus @default(PENDING)
  journalistId String
  approvedById String?
  isActive     Boolean      @default(true)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  @@index([status])
  @@index([region])
}

// ── FAMILIES ──────────────────────────────────────────

model Family {
  id           String       @id @default(cuid())
  slug         String       @unique
  name         String
  members      Int?
  location     String?
  country      String       @default("Somalia")
  region       String       @default("Gedo")
  district     String?
  village      String?
  situation    String?
  story        String       @db.Text
  need         String?
  imageUrl     String?
  phoneContact String?
  goalAmount   Decimal      @db.Decimal(12, 2)
  raisedAmount Decimal      @default(0) @db.Decimal(12, 2)
  currency     String       @default("USD")
  status       ReportStatus @default(PENDING)
  journalistId String
  approvedById String?
  isActive     Boolean      @default(true)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  @@index([status])
  @@index([region])
}

// ── STORIES / NEWS ────────────────────────────────────

model Story {
  id           String      @id @default(cuid())
  slug         String      @unique
  title        String
  content      String      @db.Text
  summary      String?
  imageUrl     String?
  // JOURNALIST = written by journalist, AUTO = system-generated, AI = AI-generated
  source       StorySource @default(JOURNALIST)
  category     String?     // success, milestone, farming, agriculture, seasonal, news
  region       String?
  status       ReportStatus @default(PENDING)
  authorId     String?     // journalist or null for system/AI
  approvedById String?
  relatedType  String?     // student, family, case
  relatedId    String?     // ID of related entity
  publishedAt  DateTime?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  @@index([status])
  @@index([source])
  @@index([category])
}

enum StorySource {
  JOURNALIST
  AUTO
  AI
}

// ── DONATIONS ─────────────────────────────────────────

model Donation {
  id              String    @id @default(cuid())
  userId          String
  reportId        String?
  amount          Decimal   @db.Decimal(12, 2)
  currency        String    @default("USD")
  paymentMethod   String    @default("STRIPE")
  stripePaymentId String?   @unique
  status          String    @default("PENDING")
  isAnonymous     Boolean   @default(false)
  donorMessage    String?
  receiptSentAt   DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  user   User   @relation(fields: [userId], references: [id])
  report Report? @relation(fields: [reportId], references: [id])

  @@index([reportId])
  @@index([userId])
}

// ── FUND POOL (Financial Core) ────────────────────────

model FundPool {
  id             String   @id @default(cuid())
  reportId       String   @unique
  totalDeposited Decimal  @default(0) @db.Decimal(12, 2)
  totalSpent     Decimal  @default(0) @db.Decimal(12, 2)
  balance        Decimal  @default(0) @db.Decimal(12, 2)
  status         String   @default("PENDING_CLEARANCE")
  unlockedAt     DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  report Report        @relation(fields: [reportId], references: [id])
  ledger LedgerEntry[]
}

model LedgerEntry {
  id           String   @id @default(cuid())
  fundPoolId   String
  type         String
  amount       Decimal  @db.Decimal(12, 2)
  balanceAfter Decimal  @db.Decimal(12, 2)
  reference    String
  actorId      String
  note         String?
  createdAt    DateTime @default(now())

  fundPool FundPool @relation(fields: [fundPoolId], references: [id])

  @@index([fundPoolId])
}

// ── PURCHASE ORDERS ───────────────────────────────────

model PurchaseOrder {
  id                   String              @id @default(cuid())
  poNumber             String              @unique
  reportId             String
  procurementOfficerId String
  vendorName           String
  vendorContact        String?
  totalCost            Decimal             @db.Decimal(12, 2)
  currency             String              @default("USD")
  status               PurchaseOrderStatus @default(DRAFT)
  description          String              @db.Text
  receiptUrl           String?
  approvedById         String?
  approvedAt           DateTime?
  paidAt               DateTime?
  notes                String?
  createdAt            DateTime            @default(now())
  updatedAt            DateTime            @updatedAt

  report  Report @relation(fields: [reportId], references: [id])
  officer User   @relation(fields: [procurementOfficerId], references: [id])

  @@index([reportId])
  @@index([status])
}

// ── PASSWORD RESET TOKENS ─────────────────────────────

model PasswordResetToken {
  id        String   @id @default(cuid())
  email     String
  token     String   @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())

  @@index([email])
  @@index([token])
}

// ── AUDIT LOG (append-only) ───────────────────────────

model AuditLog {
  id         String   @id @default(cuid())
  action     String
  actorId    String
  actorRole  Role
  actorIp    String   @default("unknown")
  reportId   String?
  targetId   String?
  targetType String?
  metadata   Json?
  createdAt  DateTime @default(now())

  actor  User    @relation(fields: [actorId], references: [id])
  report Report? @relation(fields: [reportId], references: [id])

  @@index([actorId])
  @@index([action])
  @@index([createdAt])
}
